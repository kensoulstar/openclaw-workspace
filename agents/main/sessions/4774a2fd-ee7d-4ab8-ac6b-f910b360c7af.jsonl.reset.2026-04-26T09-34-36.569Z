{"type":"message","id":"335a4a7b","parentId":"00bfed9f","timestamp":"2026-04-26T07:46:31.114Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"ComfyUI has its own venv with Python and torch is available with CUDA support. The ComfyUI server is not running yet (it was waiting for interactive input). Let me write a Python script that directly interacts with the ComfyUI API (not the management script) to:\n1. Start the ComfyUI main.py as a background process\n2. Wait for it to be ready\n3. Submit a workflow via the API\n\nLet me write a comprehensive Python script that handles everything."},{"type":"toolCall","id":"ollama_call_193713d1-a2cb-4a6f-87a8-3c353ff6a94a","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nComfyUI 一键生成脚本\n功能：\n  1. 启动 ComfyUI 主服务（后台运行）\n  2. 等待服务就绪\n  3. 提交图片生成任务（Img2Img）\n  4. 下载结果图片\n  5. 打印输出路径\n\"\"\"\n\nimport subprocess\nimport time\nimport os\nimport sys\nimport requests\nimport json\nimport shutil\nfrom pathlib import Path\n\n# ========== 配置区 ==========\nCOMFYUI_DIR = Path(\"/home/kensoulstar/ComfyUI\")\nCOMFYUI_HOST = \"127.0.0.1\"\nCOMFYUI_PORT = 8188\nCOMFYUI_URL = f\"http://{COMFYUI_HOST}:{COMFYUI_PORT}\"\n\nREF_IMAGE = \"/home/kensoulstar/图片/截图/截图 2026-04-26 15-34-07.png\"\nOUTPUT_DIR = COMFYUI_DIR / \"output\"\n\nPOSITIVE_PROMPT = \"portrait of a beautiful woman, sharp facial features, soft lighting, cinematic detail, high quality, photorealistic\"\nNEGATIVE_PROMPT = \"low quality, blurry, distortion, bad anatomy, deformed, ugly\"\nSEED = 12345\nSTEPS = 25\nCFG = 7.0\nDENOISE = 0.7\nWIDTH = 1024\nHEIGHT = 1024\n# ============================\n\n\ndef log(msg):\n    print(f\"[ComfyUI] {msg}\", flush=True)\n\n\ndef is_server_up():\n    try:\n        r = requests.get(f\"{COMFYUI_URL}/system_stats\", timeout=2)\n        return r.status_code == 200\n    except:\n        return False\n\n\ndef wait_for_server(timeout=60):\n    log(f\"等待 ComfyUI 服务启动（最多 {timeout}s）...\")\n    start = time.time()\n    while time.time() - start < timeout:\n        if is_server_up():\n            log(\"服务已就绪\")\n            return True\n        time.sleep(2)\n    return False\n\n\ndef start_comfyui():\n    \"\"\"启动 ComfyUI 主服务（后台）\"\"\"\n    log(\"启动 ComfyUI 主服务...\")\n    venv_python = COMFYUI_DIR / \"venv/bin/python\"\n    main_py = COMFYUI_DIR / \"main.py\"\n\n    # 先尝试找已有的 comfyui 进程\n    proc = subprocess.Popen(\n        [str(venv_python), str(main_py),\n         \"--listen\", COMFYUI_HOST,\n         \"--port\", str(COMFYUI_PORT),\n         \"--output\", str(OUTPUT_DIR)],\n        cwd=str(COMFYUI_DIR),\n        stdout=subprocess.DEVNULL,\n        stderr=subprocess.DEVNULL,\n        preexec_fn=os.setsid\n    )\n    log(f\"ComfyUI 进程 PID={proc.pid} 启动中...\")\n    return proc\n\n\ndef get_models():\n    \"\"\"获取可用模型列表\"\"\"\n    try:\n        r = requests.get(f\"{COMFYUI_URL}/api/object_info\", timeout=10)\n        if r.status_code != 200:\n            return []\n        info = r.json()\n        # 找 checkpoint loader\n        checkpoints = []\n        for key, val in info.items():\n            if val.get(\"class_type\") in [\"CheckpointLoaderSimple\", \"CheckpointLoader\", \"StandardLoader\"]:\n                checkpoints.append(key)\n        return checkpoints\n    except Exception as e:\n        log(f\"获取模型列表失败: {e}\")\n        return []\n\n\ndef submit_workflow():\n    \"\"\"\n    构建并提交 Img2Img workflow\n    使用 ComfyUI 原生 API 格式\n    \"\"\"\n    prompt_text = json.dumps({\n        \"3\": {\n            \"class_type\": \"CheckpointLoaderSimple\",\n            \"inputs\": {\n                \"ckpt_name\": \"sd3.5_medium.safetensors\"\n            }\n        },\n        \"4\": {\n            \"class_type\": \"CLIPTextEncode\",\n            \"inputs\": {\n                \"text\": POSITIVE_PROMPT,\n                \"clip\": [\"3\", 0]\n            }\n        },\n        \"5\": {\n            \"class_type\": \"CLIPTextEncode\",\n            \"inputs\": {\n                \"text\": NEGATIVE_PROMPT,\n                \"clip\": [\"3\", 1]\n            }\n        },\n        \"6\": {\n            \"class_type\": \"LoadImage\",\n            \"inputs\": {\n                \"image\": os.path.basename(REF_IMAGE),\n                \"upload\": \"upload\"\n            }\n        },\n        \"7\": {\n            \"class_type\": \"KSampler\",\n            \"inputs\": {\n                \"model\": [\"3\", 0],\n                \"positive\": [\"4\", 0],\n                \"negative\": [\"5\", 0],\n                \"seed\": SEED,\n                \"steps\": STEPS,\n                \"cfg\": CFG,\n                \"sampler_name\": \"euler\",\n                \"scheduler\": \"normal\",\n                \"denoise\": DENOISE\n            }\n        },\n        \"8\": {\n            \"class_type\": \"VAEDecode\",\n            \"inputs\": {\n                \"sample\": [\"7\", 0],\n                \"vae\": [\"3\", 2]\n            }\n        },\n        \"9\": {\n            \"class_type\": \"SaveImage\",\n            \"inputs\": {\n                \"images\": [\"8\", 0],\n                \"filename_prefix\": \"gen_beauty\"\n            }\n        }\n    })\n\n    # 上传图片\n    log(f\"上传参考图: {REF_IMAGE}\")\n    with open(REF_IMAGE, \"rb\") as f:\n        files = {\"file\": (os.path.basename(REF_IMAGE), f, \"image/png\")}\n        upload_r = requests.post(f\"{COMFYUI_URL}/upload/image\", files=files, timeout=30)\n    if upload_r.status_code != 200:\n        log(f\"图片上传失败: {upload_r.status_code} {upload_r.text}\")\n        # 尝试直接提交\n    else:\n        log(\"图片上传成功\")\n\n    # 提交任务\n    log(\"提交生成任务...\")\n    r = requests.post(\n        f\"{COMFYUI_URL}/prompt\",\n        json={\"prompt\": json.loads(prompt_text)},\n        timeout=30\n    )\n    if r.status_code != 200:\n        log(f\"任务提交失败: {r.status_code} {r.text}\")\n        return None\n\n    data = r.json()\n    log(f\"任务已提交，prompt_id={data.get('prompt_id')}\")\n    return data.get(\"prompt_id\")\n\n\ndef get_result(prompt_id, timeout=300):\n    \"\"\"轮询等待结果\"\"\"\n    log(f\"等待生成完成（最多 {timeout}s）...\")\n    start = time.time()\n    while time.time() - start < timeout:\n        r = requests.get(f\"{COMFYUI_URL}/history/{prompt_id}\", timeout=10)\n        if r.status_code == 200:\n            data = r.json()\n            if prompt_id in data:\n                outputs = data[prompt_id].get(\"outputs\", {})\n                for node_id, out in outputs.items():\n                    if \"images\" in out:\n                        return out[\"images\"]\n        time.sleep(5)\n    return None\n\n\ndef main():\n    # 1. 启动服务\n    proc = start_comfyui()\n\n    # 2. 等待就绪\n    if not wait_for_server(timeout=90):\n        log(\"服务启动超时，请手动检查\")\n        sys.exit(1)\n\n    # 3. 提交任务\n    prompt_id = submit_workflow()\n    if not prompt_id:\n        sys.exit(1)\n\n    # 4. 等待结果\n    images = get_result(prompt_id, timeout=300)\n    if images:\n        log(f\"生成成功！共 {len(images)} 张图：\")\n        for img in images:\n            fname = img.get(\"filename\", \"unknown\")\n            fpath = OUTPUT_DIR / fname\n            print(str(fpath))\n    else:\n        log(\"生成超时，未获取到结果\")\n        sys.exit(1)\n\n    # 5. 清理进程\n    log(\"关闭 ComfyUI 服务...\")\n    os.killpg(os.getpgid(proc.pid), 9)\n\n\nif __name__ == \"__main__\":\n    main()\n","path":"/home/kensoulstar/ComfyUI/run_gen.py"}}],"stopReason":"toolUse","api":"openai-completions","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":68204,"output":1875,"cacheRead":0,"cacheWrite":0,"totalTokens":70079,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1777189591114}}
