 $(document).ready(function(e) {      var url= \"/Index_getslide_place_info.shtml\";\t  $(\"#ertop\").load(url)});                                            信息中心          INFO               信息中心         公司新闻公司公告媒体聚焦                                 $(\".mainbox .leftbox .title\").click(function(){\t    $(this).parents(\".leftbox\").find(\".navlist\").toggle();\t  })  $(window).resize(function(){\t    var w=$(window).width()\t\tif(w>600){\t\t\t $(\".mainbox .leftbox .navlist\").show();\t\t\t  \t\t\t}\t  })\t                                                  公司新闻               您的当前位置：首页&nbsp;&gt;&nbsp;公司新闻                                                                               里伍铜业走进华为深入学习——寻道数字化转型与创新管理              发布时间：2026-03-25 &nbsp;&nbsp;&nbsp;访问量：441                                                                                                                                                                                           为深入学习和借鉴世界一流企业的管理精髓与创新实践，加速推动公司管理升级与数字化转型进程，3月18日至21日，公司组织高、中层管理人员赴深圳、东莞华为总部基地开展了为期四天的对标学习。本次学习行程安排紧实、内容丰富，通过授课、实地参观、参与论坛及深度交流等多种形式，系统学习了华为在文化构建、人才管理、数字化转型及行业生态建设等方面的先进经验，为公司进一步优化矿山运营管理、推动智能化矿山建设提供了有益借鉴。学习期间，首先通过《践行与传承-华为文化与核心价值观分享》《人才管理体系建设与实践》等专题课程，学员们系统学习了华为“以客户为中心，以奋斗者为本”的文化内核。课程深入剖析了华为如何将价值观转化为组织行为，以及在全球化发展中构建起的人才“选、育、用、留”机制，为公司强化组织韧性、优化人才管理体系提供了深刻启发。其次，深度参与了华为“合作伙伴大会2026”，全体学员现场聆听了大会主题演讲，并分专题参加了产品分论坛与行业峰会。相关业务负责人重点参加了钢铁有色论坛及川藏油气矿山分论坛，围绕矿山智能化开采、数字化转型、产业链协同及高海拔复杂地质运营等议题与行业专家深入交流，进一步明晰了华为在矿山智能化领域的生态布局与合作路径。再次，通过《华为数字化转型之道》《人工智能及AI大模型分享》等课程学习，学员们系统了解了华为自身从流程变革到数字化、智能化的转型路径与核心方法论。深入探讨了AI大模型在找矿、安全监测、设备预测性维护、工艺优化等场景中的应用潜力。最后，在深圳坂田基地与东莞松山湖基地的实地参观及高层交流中，学员们切身感受了华为在科技创新、工作环境设计与员工关怀上的先进理念，并就如何将华为管理理念与矿山行业实际相结合、系统推动数字化转型进行了深入研讨。本次学习既是一次开阔视野之旅，也是一次深化管理认知、凝聚变革共识的“充电”之行。通过对华为的系统性对标学习，公司高、中层管理人员对如何构建卓越组织文化、如何系统推进矿山数字化、智能化转型，如何有效融入产业智能生态有了更深的理解。下一步，公司将组织专题分享会，梳理学习成果，将华为的先进理念与实践经验，结合公司实际转化为具体的行动举措，重点围绕矿山智能化建设、数字化转型路径、人才队伍优化等方面，形成切实可行的行动举措，持续推动管理创新与业务高质量发展。              上一条：智汇矿山·科创领航 ——院士赋能与博士后科研工作站启航              下一条：十二届州委第九轮第三巡察组巡察里伍铜业党委工作动员会召开              返回列表&nbsp;&nbsp;                                                                  $(document).ready(function(e) {      $(\".showus img\").each(function(index, element) {\t\t var w=$(window).width();            var w1=$(\".showus img\").eq(index).width();\t\t if(w1>w)\t\t   {\t\t     $(\".showus img\").eq(index).width(w)\t\t   }    \t\t      });});                                          关于我们                                                       组织结构公司简介发展历程联系我们发展战略                                                                                    企业形象                                                       企业文化企业故事企业风采                                                                                    公司产业                                                        矿产资源水电资源资源勘查金融业务                                                                                    信息中心                                                       公司新闻公司公告媒体聚焦                                                                                    社会责任                                                       科技创新安全环保和谐发展                                                                                    党的建设                                                       纪检监察群团工作公司党建                                                                                    人力资源                                                       人才理念人才招聘信息人才招聘流程\t\t\t\t\t  人才发展战略                                                                                    招标采购                                                        招标采购文件流标或终止公告评标结果公示招标采购结果公示                                                                                              地址:四川省康定市炉城镇向阳街 137 号&nbsp; &nbsp;&nbsp;版权所有：四川里伍铜业股份有限公司 &nbsp; &nbsp; &nbsp; 备案编号：蜀ICP备2023009531号-1                                          var _hmt = _hmt || [];(function() {  var hm = document.createElement(\"script\");  hm.src = \"https://hm.baidu.com/hm.js?2cef0011912b2d5ba8adc96be7aa08f8\";  var s = document.getElementsByTagName(\"script\")[0];   s.parentNode.insertBefore(hm, s);})();if (!(/msie [6|7|8|9]/i.test(navigator.userAgent))){\tnew WOW().init();}; \n\n=== Article 850 ===\n智汇矿山·科创领航 ——院士赋能与博士后科研工作站启航_四川里伍铜业股份有限公司                                                    网站首页               关于我们               企业形象               公司产业               信息中心               社会责任               党群工作               人力资源               投资者关系               招标采购                                                               网站首页               关于我们                                         组织结构公司简介发展历程联系我们发展战略                                                企业形象                                         企业文化企业故事企业风采                                                公司产业                                         矿产资源水电资源资源勘查金融业务                                                信息中心                                        公司新闻公司公告媒体聚焦                                                社会责任                                        科技创新安全环保和谐发展                                                党群工作                                        纪检监察群团工作公司党建                                                人力资源                                        人才理念人才招聘信息人才招聘流程\t\t\t\t\t  人才发展战略                                                投资者关系                                         通知公告                       在线留言                                                               招标采购                                         招标采购文件流标或终止公告评标结果公示招标采购结果公示                                                                          $(document).ready(function(e) {     $(\".headbox .box .menu ul li\").hover(function(){\t\t   $(this).find(\"ul\").slideDown();\t\t },function(){\t\t   $(this).find(\"ul\").slideUp();\t\t })});        $(document).ready(function(e) {      var url= \"/Index_getslide_place_info.shtml\";\t  $(\"#ertop\").load(url)});                                            信息中心          INFO               信息中心         公司新闻公司公告媒体聚焦                                 $(\".mainbox .leftbox .title\").click(function(){\t    $(this).parents(\".leftbox\").find(\".navlist\").toggle();\t  })  $(window).resize(function(){\t    var w=$(window).width()\t\tif(w>600){\t\t\t $(\".mainbox .leftbox .navlist\").show();\t\t\t  \t\t\t}\t  })\t                                                  公司新闻               您的当前位置：首页&nbsp;&gt;&nbsp;公司新闻                                                                               智汇矿山·科创领航 ——院士赋能与博士后科研工作站启航              发布时间：2026-03-24 &nbsp;&nbsp;&nbsp;访问量：414                                                                                                                                                                                           3月23日，里伍铜业隆重举行“中国地质科学院四川里伍铜业股份有限公司博士后科研工作站”揭牌仪式。中国工程院院士毛景文，中国地质科学院矿产资源研究所研究员肖克炎，甘孜州人民政府副秘书长张雪峰，中国地质科学院、九龙县人民政府、甘孜州自规局、甘孜州国资委相关领导出席活动。成都地调中心、成都理工大学、华为等相关单位领导和专家共同见证揭牌仪式。张雪峰表示，博士后科研工作站揭牌是全州矿业发展与科技创新的里程碑事件。甘孜作为国家生态安全屏障与矿产资源富集区，始终坚持“生态优先、绿色发展”理念。工作站落地，是深化产学研合作、汇聚高端人才的关键举措，既为里伍铜业注入动能，更搭建全州矿业高质量发展平台。他强调，一是强化政策保障，持续优化营商环境，全方位支撑工作站运行、人才引育与成果转化；二是深化政企研协同，聚焦矿山关键技术攻关，破解产业发展瓶颈；三是加速成果落地，赋能产业发展，助推甘孜由“资源大州”迈向“产业强州”跨越。毛景文表示，里伍铜业扎根雪域康巴三十余载，始终坚守矿业报国初心，为地方经济发展贡献突出，在绿色开采、深部找矿、高海拔资源开发与生态保护协同等领域探索出宝贵新路径。工作站的设立，是产学研深度融合、科技赋能矿业高质量发展的关键之举。他指出，全球矿业加速迈向智能化、绿色化、低碳化，深部资源勘探、矿山安全、固废利用等亟需科技支撑。中国地质科学院将以工作站为纽带，一是聚焦深部找矿、绿色充填、智能矿山等关键技术攻关；二是吸引和培育复合型人才，为藏区矿业发展提供智力支撑；三是构建“科研院所+高校+企业”创新联合体，为矿山高质量发展注入科技动能。同时寄语进站青年博士扎根矿山，让成果赋能产业，在服务国家战略中实现人生价值。              上一条：喜报！里伍铜业获准设立博士后科研工作站              下一条：里伍铜业走进华为深入学习——寻道数字化转型与创新管理              返回列表&nbsp;&nbsp;                                                                  $(document).ready(function(e) {      $(\".showus img\").each(function(index, element) {\t\t var w=$(window).width();            var w1=$(\".showus img\").eq(index).width();\t\t if(w1>w)\t\t   {\t\t     $(\".showus img\").eq(index).width(w)\t\t   }    \t\t      });});                                          关于我们                                 