sie [6|7|8|9]/i.test(navigator.userAgent))){\tnew WOW().init();}; \n\n=== Article 852 ===\n里伍铜业走进华为深入学习——寻道数字化转型与创新管理_四川里伍铜业股份有限公司                                                    网站首页               关于我们               企业形象               公司产业               信息中心               社会责任               党群工作               人力资源               投资者关系               招标采购                                                               网站首页               关于我们                                         组织结构公司简介发展历程联系我们发展战略                                                企业形象                                         企业文化企业故事企业风采                                                公司产业                                         矿产资源水电资源资源勘查金融业务                                                信息中心                                        公司新闻公司公告媒体聚焦                                                社会责任                                        科技创新安全环保和谐发展                                                党群工作                                        纪检监察群团工作公司党建                                                人力资源                                        人才理念人才招聘信息人才招聘流程\t\t\t\t\t  人才发展战略                                                投资者关系                                         通知公告                       在线留言                                                               招标采购                                         招标采购文件流标或终止公告评标结果公示招标采购结果公示                                                                          $(document).ready(function(e) {     $(\".headbox .box .menu ul li\").hover(function(){\t\t   $(this).find(\"ul\").slideDown();\t\t },function(){\t\t   $(this).find(\"ul\").slideUp();\t\t })});        $(document).ready(function(e) {      var url= \"/Index_getslide_place_info.shtml\";\t  $(\"#ertop\").load(url)});                                            信息中心          INFO               信息中心         公司新闻公司公告媒体聚焦                                 $(\".mainbox .leftbox .title\").click(function(){\t    $(this).parents(\".leftbox\").find(\".navlist\").toggle();\t  })  $(window).resize(function(){\t    var w=$(window).width()\t\tif(w>600){\t\t\t $(\".mainbox .leftbox .navlist\").show();\t\t\t  \t\t\t}\t  })\t                                                  公司新闻               您的当前位置：首页&nbsp;&gt;&nbsp;公司新闻                                                                               里伍铜业走进华为深入学习——寻道数字化转型与创新管理              发布时间：2026-03-25 &nbsp;&nbsp;&nbsp;访问量：441                                                                                                                                                                                           为深入学习和借鉴世界一流企业的管理精髓与创新实践，加速推动公司管理升级与数字化转型进程，3月18日至21日，公司组织高、中层管理人员赴深圳、东莞华为总部基地开展了为期四天的对标学习。本次学习行程安排紧实、内容丰富，通过授课、实地参观、参与论坛及深度交流等多种形式，系统学习了华为在文化构建、人才管理、数字化转型及行业生态建设等方面的先进经验，为公司进一步优化矿山运营管理、推动智能化矿山建设提供了有益借鉴。学习期间，首先通过《践行与传承-华为文化与核心价值观分享》《人才管理体系建设与实践》等专题课程，学员们系统学习了华为“以客户为中心，以奋斗者为本”的文化内核。课程深入剖析了华为如何将价值观转化为组织行为，以及在全球化发展中构建起的人才“选、育、用、留”机制，为公司强化组织韧性、优化人才管理体系提供了深刻启发。其次，深度参与了华为“合作伙伴大会2026”，全体学员现场聆听了大会主题演讲，并分专题参加了产品分论坛与行业峰会。相关业务负责人重点参加了钢铁有色论坛及川藏油气矿山分论坛，围绕矿山智能化开采、数字化转型、产业链协同及高海拔复杂地质运营等议题与行业专家深入交流，进一步明晰了华为在矿山智能化领域的生态布局与合作路径。再次，通过《华为数字化转型之道》《人工智能及AI大模型分享》等课程学习，学员们系统了解了华为自身从流程变革到数字化、智能化的转型路径与核心方法论。深入探讨了AI大模型在找矿、安全监测、设备预测性维护、工艺优化等场景中的应用潜力。最后，在深圳坂田基地与东莞松山湖基地的实地参观及高层交流中，学员们切身感受了华为在科技创新、工作环境设计与员工关怀上的先进理念，并就如何将华为管理理念与矿山行业实际相结合、系统推动数字化转型进行了深入研讨。本次学习既是一次开阔视野之旅，也是一次深化管理认知、凝聚变革共识的“充电”之行。通过对华为的系统性对标学习，公司高、中层管理人员对如何构建卓越组织文化、如何系统推进矿山数字化、智能化转型，如何有效融入产业智能生态有了更深的理解。下一步，公司将组织专题分享会，梳理学习成果，将华为的先进理念与实践经验，结合公司实际转化为具体的行动举措，重点围绕矿山智能化建设、数字化转型路径、人才队伍优化等方面，形成切实可行的行动举措，持续推动管理创新与业务高质量发展。              上一条：智汇矿山·科创领航 ——院士赋能与博士后科研工作站启航              下一条：十二届州委第九轮第三巡察组巡察里伍铜业党委工作动员会召开              返回列表&nbsp;&nbsp;                                                                  $(document).ready(function(e) {      $(\".showus img\").each(function(index, element) {\t\t var w=$(window).width();            var w1=$(\".showus img\").eq(index).width();\t\t if(w1>w)\t\t   {\t\t     $(\".s