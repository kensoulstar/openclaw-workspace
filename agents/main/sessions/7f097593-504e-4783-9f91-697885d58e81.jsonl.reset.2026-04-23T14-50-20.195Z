ef=\"/Single_index_id_2.shtml\">联系我们</a></li><li><a href=\"/Single_index_id_3.shtml\">发展战略</a></li>                  </ul>\r\n               </div>\r\n            </div>\r\n            \r\n            <div class=\"onebox\">\r\n               <div class=\"tit\">企业形象</div>\r\n               <div class=\"list\">\r\n                  <ul>\r\n                      <li><a href=\"/Single_index_id_19.shtml\">企业文化</a></li><li><a href=\"/Single_index_id_27.shtml\">企业故事</a></li><li><a href=\"/Single_index_id_20.shtml\">企业风采</a></li>                  </ul>\r\n               </div>\r\n            </div>\r\n            \r\n            <div class=\"onebox\">\r\n               <div class=\"tit\">公司产业</div>\r\n               <div class=\"list\">\r\n                  <ul>\r\n                       <li><a href=\"/News_lists_sort_12.shtml\">矿产资源</a></li><li><a href=\"/News_lists_sort_11.shtml\">水电资源</a></li><li><a href=\"/News_lists_sort_10.shtml\">资源勘查</a></li><li><a href=\"/News_lists_sort_9.shtml\">金融业务</a></li>                  </ul>\r\n               </div>\r\n            </div>\r\n            \r\n            <div class=\"onebox\">\r\n               <div class=\"tit\">信息中心</div>\r\n               <div class=\"list\">\r\n                  <ul>\r\n                      <li><a href=\"/News_lists_sort_15.shtml\">公司新闻</a></li><li><a href=\"/News_lists_sort_14.shtml\">公司公告</a></li><li><a href=\"/News_lists_sort_13.shtml\">媒体聚焦</a></li>                  </ul>\r\n               </div>\r\n            </div>\r\n            \r\n            <div class=\"onebox\">\r\n               <div class=\"tit\">社会责任</div>\r\n               <div class=\"list\">\r\n                  <ul>\r\n                      <li><a href=\"/Single_index_id_32.shtml\">科技创新</a></li><li><a href=\"/Single_index_id_25.shtml\">安全环保</a></li><li><a href=\"/Single_index_id_22.shtml\">和谐发展</a></li>                  </ul>\r\n               </div>\r\n            </div>\r\n            \r\n            <div class=\"onebox\">\r\n      