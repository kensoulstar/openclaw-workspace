"$dir\" /home/kensoulstar/.openclaw/workspace/skills/ 2>/dev/null && echo \"✓ $name (from $filename)\" || \\\n          # Try extracting the dir directly from zip structure\n          if [[ -d \"/tmp/$base_name/$name\" ]]; then\n            cp -r \"/tmp/$base_name/$name\" /home/kensoulstar/.openclaw/workspace/skills/ && echo \"✓ $name (from $filename)\"\n          fi\n      else\n        echo \"- $name already installed\"\n      fi\n    done\n  else\n    # Maybe it's a single skill at zip root or has different structure\n    base_name=\"${filename%.zip}\"\n    if [[ -d \"/tmp/$base_name/SKILL.md\" ]]; then\n      name=$(echo \"$base_name\" | sed 's/_[0-9]*\\.[0-9]*\\.[0-9]*//; s/-[0-9]*\\.[0-9]*\\.[0-9]*//')\n      if [ ! -d \"/home/kensoulstar/.openclaw/workspace/skills/$name\" ]; then\n        cp -r \"/tmp/$base_name\" /home/kensoulstar/.openclaw/workspace/skills/ && echo \"✓ $name (from $filename)\"\n      else\n        echo \"- $name already installed\"\n      fi\n    elif [[ -f \"/tmp/$base_name/SKILL.md\" ]]; then\n      # Single file SKILL.md at zip root\n      name=$(echo \"$base_name\" | sed 's/_[0-9]*\\.[0-9]*\\.[0-9]*//; s/-[0-9]*\\.[0-9]*\\.[0-9]*//')\n      if [ ! -d \"/home/kensoulstar/.openclaw/workspace/skills/$name\" ]; then\n        mkdir -p /home/kensoulstar/.openclaw/workspace/skills/$name\n        cp /tmp/$base_name/SKILL.md /home/kensoulstar/.openclaw/workspace/skills/$name/ 2>/dev/null && echo \"✓ $name (from $filename)\"\n      else\n        echo \"- $name already installed\"\n      fi\n    else\n      # Check for any directory with SKILL.md in the extracted content\n      found=$(find \"/tmp/$base_name\" -name \"SKILL.md\" 2>/dev/null | head -1)\n      if [ -n \"$found\" ]; then\n        dir=$(dirname \"$found\")\n        name=$(basename \"$dir\")\n        if [ ! -d \"/home/kensoulstar/.openclaw/workspace/skills/$name\" ]; then\n          cp -r \"$dir\" /home/kensoulstar/.openclaw/workspace/skills/ && echo \"✓ $name (from $filename)\"\n     